# Direct Postgres connection (server-side / scripts / psql)
DATABASE_URL="YOUR-DATABASE-CONNECTION-STRING"

# Supabase client (Next.js)
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR-ANON-KEY"

# Service role (server only — never expose on the client)
SUPABASE_SERVICE_ROLE_KEY="YOUR-SERVICE-ROLE-KEY"

# Allowlist des emails autorisés à se connecter (séparés par des virgules).
# Doit être le compte créé dans Supabase → Authentication → Users.
ALLOWED_EMAILS="toi@exemple.com"
